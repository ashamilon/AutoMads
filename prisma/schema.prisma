generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IntegrationType {
  API
  DATABASE
  WEBHOOK
}

enum OrderStatus {
  DRAFT
  PENDING_CLIENT_SYNC
  AWAITING_PAYMENT
  PAID
  DELIVERY_SCHEDULED
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  INITIATED
  PAID
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  NONE
  PENDING
  BOOKED
  IN_TRANSIT
  DELIVERED
  FAILED
}

/// Tenant = one business on the SaaS platform
model Tenant {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  isActive                Boolean  @default(true)
  /// Graph API page token for sending/receiving Messenger
  facebookPageAccessToken String?
  facebookPageId          String?
  /// Random string you set in Meta webhook subscription
  facebookVerifyToken     String?
  /// First time we saw a non-null facebookPageId. Drives the "grace window"
  /// after Page connection: for 48h after this timestamp, the agent escalates
  /// any past-order question to admin instead of guessing. Auto-stamped on
  /// the first webhook turn the tenant receives if not already set.
  facebookConnectedAt     DateTime?
  /// SHA-256 hex of full tenant API key (Bearer sk_live_...); set on create / regenerate
  apiKeyHash              String?  @unique
  /// Login email. Lowercase, normalised. Set during one-time activation.
  email                   String?  @unique
  /// bcrypt hash of the dashboard password. Login requires email + password
  /// to match. The platform admin (you) cannot read the password.
  passwordHash            String?
  /// One-time activation token (SHA-256 hash). Issued when admin creates the
  /// tenant. Forwarded to the client; they open /activate?token=... to set
  /// their email + password.
  activationTokenHash     String?  @unique
  activationExpiresAt     DateTime?
  /// e.g. { "defaultOrderAmountBdt": 500, "sslcommerz": { "storeId": "..." }, "pathao": { ... } }
  settings                Json?
  /// Commerce_OS multi-tenant deltas (R1, R2, R5, R14). All optional so existing
  /// jersey demo tenant rows continue to read/write unchanged. Category-specific
  /// data lives in JSON columns; no per-category physical columns (R3.1, R3.6, R14.6).
  businessCategory        String?
  businessSubcategory     String?
  categorySchemaId        String?
  dashboardTemplate       String?
  onboardingCompletedAt   DateTime?
  onboardingState         Json?
  agentIdentity           Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  integration         TenantIntegration?
  orders              Order[]
  productMappings     ProductMapping[]
  conversations       MessengerConversation[]
  knowledgeExamples   KnowledgeExample[]
  scheduledPosts      ScheduledPost[]
  customerProfiles    CustomerProfile[]
  followUps           FollowUp[]
  agentTraces         AgentTrace[]
  sessions            TenantSession[]
  categorySchema      CategorySchema?      @relation(fields: [categorySchemaId], references: [id])
  subscription        Subscription?
  notifications       Notification[]
  invoices            Invoice[]
  paymentTransactions PaymentTransaction[]
  subscriptionLogs    SubscriptionLog[]
  paymentFailures     PaymentFailure[]
}

/// Browser-session token issued after a successful email + password login.
/// Stored as a SHA-256 hash. Auto-expires after 7 days. The cookie / bearer
/// value is only visible to the client's browser; the admin (platform owner)
/// cannot read it from the database.
model TenantSession {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@index([tenantId])
  @@index([expiresAt])
}

/// One row per tenant — holds integration mode + JSON config (credentials live here; encrypt at rest in production)
model TenantIntegration {
  id        String          @id @default(cuid())
  tenantId  String          @unique
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      IntegrationType
  /// API: { baseUrl, headers, paths: { products, createOrder, ... } }
  /// DATABASE: { engine: "mysql"|"postgres", connection: {...}, tables: {...} }
  /// WEBHOOK: { outboundUrl, outboundSecret, inboundSecret }
  config    Json
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ProductMapping {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientSku     String
  facebookLabel String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, clientSku])
  @@index([tenantId])
}

model MessengerConversation {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  psid             String
  lastUserMsgAt    DateTime  @default(now())
  lastBotMsgAt     DateTime?
  /// When set + in the future, the agent will NOT reply to inbound messages on
  /// this conversation. Used by the post-connection grace handoff (10h mute
  /// after admin escalation) and any future "human takeover" flow. After the
  /// timestamp passes, the agent automatically re-engages on the next inbound.
  agentMutedUntil  DateTime?
  /// Last extracted draft order JSON from LLM (not committed until validated)
  pendingDraftJson Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  messages MessengerMessage[]

  @@unique([tenantId, psid])
  @@index([tenantId])
}

/// Per-turn conversation history. Used for context (last N) + as a source for KnowledgeExample.
model MessengerMessage {
  id                       String                @id @default(cuid())
  conversationId           String
  conversation             MessengerConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// "user" (customer) or "assistant" (bot/operator)
  role                     String
  text                     String                @db.Text
  /// Optional list of image URLs the user attached
  imageUrls                String[]              @default([])
  /// Graph message id for this row (webhook `message.mid` when known)
  facebookMessageId        String?
  /// When the customer used Messenger "reply", the parent message id they replied to
  replyToFacebookMessageId String?
  createdAt                DateTime              @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, facebookMessageId])
}

/// Retrieved-augmented generation knowledge base — past customer→assistant pairs from imports
/// or live conversations. Embedding is stored as Float[] for in-process cosine similarity.
model KnowledgeExample {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Source: "import" | "live"
  source        String   @default("import")
  /// What the customer wrote
  userText      String   @db.Text
  /// How the merchant replied (the "voice" we want to imitate)
  assistantText String   @db.Text
  /// Embedding of userText (e.g. 768 dims for nomic-embed-text)
  embedding     Float[]
  /// Free metadata: tags, products, language, etc.
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model ScheduledPost {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform      String // "facebook" | "instagram" | "both"
  postType      String // "product_showcase" | "collection" | "story" | "custom"
  caption       String    @db.Text
  imageUrls     Json // string[] from Cloudinary
  productSkus   Json? // optional: string[] of linked product SKUs
  scheduledAt   DateTime
  publishedAt   DateTime?
  status        String    @default("scheduled") // "scheduled" | "published" | "failed" | "draft"
  fbPostId      String?
  igMediaId     String?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, scheduledAt])
  @@index([status, scheduledAt])
}

model Order {
  id                    String         @id @default(cuid())
  tenantId              String
  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Facebook sender page-scoped id
  messengerPsid         String
  /// Structured extraction from LLM (validated before client sync)
  structuredData        Json
  status                OrderStatus    @default(DRAFT)
  paymentStatus         PaymentStatus  @default(PENDING)
  deliveryStatus        DeliveryStatus @default(NONE)
  /// Id returned by client system after sync
  externalOrderId       String?
  /// SSLCommerz session / transaction references
  sslcommerzTranId      String?        @unique
  sslcommerzSessionKey  String?
  /// Pathao
  pathaoConsignmentId   String?
  pathaoMerchantOrderId String?
  totalAmount           Decimal?       @db.Decimal(12, 2)
  currency              String         @default("BDT")
  failureReason         String?
  /// "SSLCOMMERZ" | "BKASH_MANUAL" | "NAGAD_MANUAL" — which rail this order is using
  paymentMethod         String         @default("SSLCOMMERZ")
  /// Customer-supplied transaction id when paying via personal bKash/Nagad
  manualTxnId           String?
  /// Free-form note (admin or bot) about manual verification
  manualPaymentNote     String?
  /// Admin user id who marked this paid manually (audit trail)
  manuallyVerifiedBy    String?
  manuallyVerifiedAt    DateTime?
  /// Public URL of the generated invoice PDF
  invoiceUrl            String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([tenantId])
  @@index([tenantId, messengerPsid])
  @@index([sslcommerzTranId])
}

/// Per-customer (psid) profile. Stable across conversations and across PSID changes if we later
/// merge them. The conversation-level pendingDraftJson stays as the in-flight scratchpad; this
/// is the long-term record (lead score, totals, preferences).
model CustomerProfile {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  psid              String
  name              String?
  phone             String?
  address           String?
  /// 0–100; starts at 10 (just-said-hi), bumps on cart adds and orders.
  leadScore         Int       @default(10)
  /// Free-form tags ("vip", "argentina-fan", etc.)
  tags              String[]  @default([])
  /// Free-form key/value preferences (favourite size, language, etc.)
  preferences       Json?
  totalOrders       Int       @default(0)
  totalSpentBdt     Decimal   @default(0) @db.Decimal(14, 2)
  firstSeenAt       DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())
  /// Optional: when set, the bot pauses for this customer until this timestamp (phase 4).
  humanHandledUntil DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([tenantId, psid])
  @@index([tenantId])
  @@index([tenantId, lastSeenAt])
}

/// Queued autonomous actions: abandoned-cart nudges, payment-link reminders, post-delivery
/// review requests, etc. Drained by the post scheduler tick.
model FollowUp {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  psid           String
  conversationId String?
  /// "abandoned_cart" | "payment_reminder" | "delivery_review" | "custom"
  kind           String
  /// "scheduled" | "sent" | "cancelled" | "failed"
  status         String   @default("scheduled")
  runAt          DateTime
  attempts       Int      @default(0)
  lastError      String?
  /// Free-form payload (e.g. cart snapshot, suggested message).
  payload        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, runAt])
  @@index([tenantId, psid])
  @@index([tenantId, kind, status])
}

/// One row per agent step (router decision + tool result). Used for debugging hallucinations
/// and for replaying turns in the admin panel.
model AgentTrace {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId String
  psid           String
  /// Stable per-turn id grouping all steps from one inbound message.
  turnId         String
  iter           Int
  tool           String
  thought        String?  @db.Text
  args           Json?
  ok             Boolean
  observation    String   @db.Text
  errorCode      String?
  llmLatencyMs   Int?
  toolLatencyMs  Int?
  /// "terminal" | "max_iter" | "router_error" | null while in-flight
  finalReason    String?
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, conversationId, createdAt])
  @@index([turnId])
}

// ---------------------------------------------------------------------------
// Commerce_OS multi-tenant plane (R2, R10-R16, R20)
// All deltas applied via `prisma db push` only — no `prisma/migrations/` files
// (R14.3, R23.3). Category-specific data lives in JSON columns; universal
// columns `sslcommerzTranId` / `sslcommerzSessionKey` are reused for every
// gateway (R14.2, R22.4).
// ---------------------------------------------------------------------------

/// Per-category configuration: attribute fields, terminology, dashboard
/// modules, workflow rules, prompt fragments. Built-in rows ship with
/// `isBuiltIn=true` and `tenantId=null`; tenant-cloned customizations carry
/// `tenantId` (R2.1, R2.4, R3.1).
model CategorySchema {
  id                String   @id @default(cuid())
  slug              String
  version           Int      @default(1)
  attributes        Json
  variantAttributes Json
  orderAttributes   Json
  filterAttributes  Json
  terminology       Json
  dashboardModules  Json
  workflowRules     Json
  promptFragments   Json
  isBuiltIn         Boolean  @default(false)
  tenantId          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenants Tenant[]

  @@index([slug])
  @@index([tenantId])
}

/// Subscription tier definitions (Starter / Pro / Agency / Enterprise).
/// `limits` and `featureFlags` are JSON so new flags/limits can be added
/// without schema changes (R15.1, R15.2, R16.1).
model Plan {
  id           String   @id @default(cuid())
  slug         String   @unique
  displayName  String
  billingCycle String   @default("monthly")
  priceBdt     Decimal  @db.Decimal(12, 2)
  trialDays    Int      @default(14)
  limits       Json
  featureFlags Json
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
}

/// Per-tenant subscription state machine row (R10.1, R10.2). Status is one of
/// 'trial' | 'active' | 'overdue' | 'suspended' | 'cancelled'. Usage counters
/// reset on `currentPeriodStart` advance (R15.5).
model Subscription {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId             String
  plan               Plan      @relation(fields: [planId], references: [id])
  status             String
  trialEndsAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  gracePeriodEndsAt  DateTime?
  cancelledAt        DateTime?
  nextBillingAt      DateTime?
  billingCycle       String    @default("monthly")
  planLimitOverrides Json?
  usageCounters      Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  invoices             Invoice[]
  gracePeriodTrackings GracePeriodTracking[]

  @@index([status])
  @@index([currentPeriodEnd])
  @@index([gracePeriodEndsAt])
}

/// One billable period per subscription. PDF reference and the universal
/// SSLCommerz columns live here; gateway-specific columns are NOT added
/// (R11.4, R14.2, R22.4).
model Invoice {
  id                   String       @id @default(cuid())
  subscriptionId       String
  subscription         Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId             String
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodStart          DateTime
  periodEnd            DateTime
  amountBdt            Decimal      @db.Decimal(12, 2)
  currency             String       @default("BDT")
  status               String
  pdfPath              String?
  sslcommerzTranId     String?
  sslcommerzSessionKey String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  paymentTransactions PaymentTransaction[]

  @@index([tenantId])
  @@index([status])
}

/// One payment attempt per invoice. `gateway` is a free-form string so
/// SSLCommerz, AamarPay and bKash all flow through the same row shape
/// (R11.1, R14.2, R22.4). Only universal SSLCommerz columns are stored.
model PaymentTransaction {
  id                   String   @id @default(cuid())
  invoiceId            String
  invoice              Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenantId             String
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  gateway              String
  amountBdt            Decimal  @db.Decimal(12, 2)
  status               String
  sslcommerzTranId     String?  @unique
  sslcommerzSessionKey String?
  rawPayload           Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  paymentFailures PaymentFailure[]

  @@index([tenantId])
  @@index([status])
}

/// Audit row written on every Subscription state transition (R10.7, R12.7,
/// R15.6). `actor` is one of 'system' | 'super_admin:<id>' | 'tenant:<id>'.
model SubscriptionLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  reason     String
  actor      String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
}

/// One row per failed payment attempt. Subscription status is NOT changed
/// here — that is handled by the grace-period scheduler (R11.3).
model PaymentFailure {
  id            String              @id @default(cuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionId String?
  transaction   PaymentTransaction? @relation(fields: [transactionId], references: [id])
  reason        String
  rawPayload    Json?
  createdAt     DateTime            @default(now())

  @@index([tenantId, createdAt])
}

/// Tracks Day 0 / Day 1 / Day 2 grace-period warnings so re-firing the cron
/// never double-sends (R12.1, R12.2, R12.3). The `(subscriptionId, day,
/// channel)` unique constraint enforces the idempotency.
model GracePeriodTracking {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId       String
  day            Int
  warningSentAt  DateTime     @default(now())
  channel        String

  @@unique([subscriptionId, day, channel])
}

/// Persisted notifications across all channels. The dashboard channel reads
/// unread rows; email / telegram / whatsapp / facebook adapters update
/// `status`, `attempts`, `sentAt` (R13.3, R13.4, R13.5).
model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel   String
  type      String
  payload   Json
  status    String
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  sentAt    DateTime?
  readAt    DateTime?

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

/// Platform-operator account, distinct from TenantSession (R20.7, R6.5).
/// Passwords hashed with bcryptjs (R23.5). The first SuperAdmin row is
/// seeded by `bootstrapSuperAdmin()` from `SUPER_ADMIN_BOOTSTRAP_EMAIL`
/// with `passwordHash=null` and a one-time `activationTokenHash`; the
/// platform operator opens `/admin/auth/activate?token=...` to choose a
/// password and the token is then burned (idempotent re-runs are no-ops).
model SuperAdmin {
  id                  String    @id @default(cuid())
  email               String    @unique
  /// bcryptjs hash. Null until the activation flow consumes the token.
  passwordHash        String?
  /// SHA-256 of the one-time activation token. Plaintext is shown to the
  /// operator once during bootstrap; only the hash is stored.
  activationTokenHash String?   @unique
  activationExpiresAt DateTime?
  name                String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

/// Browser session for a SuperAdmin. Mirrors the TenantSession shape but
/// has no `tenantId` — every tenant operation requires an explicit tenantId
/// parameter at the controller level (R6.5, R20.7).
model SuperAdminSession {
  id           String   @id @default(cuid())
  superAdminId String
  tokenHash    String   @unique
  expiresAt    DateTime
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
  lastSeen     DateTime @default(now())

  @@index([superAdminId])
  @@index([expiresAt])
}


/// Singleton platform-level settings. Holds platform-billing credentials
/// (the SaaS operator's own SSLCommerz store) and other per-deployment
/// knobs the admin UI lets you edit at runtime — without an env restart.
///
/// Convention: the application enforces a single row by always reading /
/// upserting `id = 'platform'`. Storing as a model (not a JSON column on
/// some other table) keeps the read path indexable and the write path
/// transactional.
///
/// `secrets` is a JSON column for credentials. It is intentionally generic
/// so future gateways (AamarPay subscription, bKash subscription) can
/// reuse the same surface without a schema change.
model PlatformSettings {
  id        String   @id @default("platform")
  /// JSON blob keyed by gateway slug. Shape:
  /// {
  ///   sslcommerzSubscription: {
  ///     storeId: string,
  ///     storePassword: string,
  ///     isSandbox: boolean
  ///   }
  /// }
  secrets   Json
  /// Last actor that updated this row (for audit). Format `super_admin:<id>` or `legacy-admin-key`.
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
