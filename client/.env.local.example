# Backend API (Express + Prisma) — must match where npm run dev runs for API (default :4000)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public URL of the API used for Meta / SSLCommerz webhooks (often same as API; use ngrok/https in prod)
NEXT_PUBLIC_WEBHOOK_BASE_URL=http://localhost:4000

# Optional: set to "session" to store the key in sessionStorage only (clears when the tab closes).
# Default uses localStorage so you stay signed in until Sign out.
# NEXT_PUBLIC_AUTH_PERSIST=session
