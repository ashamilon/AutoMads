NODE_ENV=development
PORT=4000

# Local PostgreSQL (default). Use whatever user/password/database you set up locally.
# Example: postgresql://postgres:postgres@localhost:5432/automads
DATABASE_URL=

# Optional: encrypt tenant secrets at rest (32-byte hex = 64 chars); leave empty to store plaintext JSON (dev only)
ENCRYPTION_KEY=

# Ollama — name must match output of: ollama list  (e.g. cloud tag)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:31b-cloud
# Optional: ms; default 600000 (10m) for slow / first cloud pull
# OLLAMA_TIMEOUT_MS=600000

# RAG: max KnowledgeExample rows loaded per tenant (each row has a large embedding). Lower if you see Postgres statement_timeout.
# RAG_KNOWLEDGE_MAX_ROWS=2000

# SaaS admin API (tenant provisioning + browser dashboard at /admin/index.html)
ADMIN_API_KEY=change-me-long-random

# SSLCommerz (defaults can be overridden per tenant in integration config if needed)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true

# Public URL of this API (for Facebook webhooks, SSL IPN redirect)
PUBLIC_BASE_URL=https://your-domain.com

# Public URL of the Next.js portal where /login, /activate, /portal/* live.
# Used to build activation links the admin forwards to clients. Locally this
# is http://localhost:3000; in production point it at the deployed portal
# domain (e.g. https://app.your-domain.com).
PUBLIC_PORTAL_URL=http://localhost:3000

# Comma-separated list of browser origins allowed to call the API with
# credentials. In production this MUST include the dashboard portal
# subdomain so the Next.js client can authenticate. Empty = allow all
# (development convenience only — never leave empty in production).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Optional: Cloudinary Admin API — fallback when a tenant has not saved keys in Portal → Settings → Catalog
# (or Catalog → Cloudinary). Per-tenant keys in workspace settings override these. Rotate keys if exposed.
# Cloud name = Dashboard URL subdomain.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional default prefix for catalog assets only, e.g. jerseys/wc26/
# CLOUDINARY_CATALOG_PREFIX=
