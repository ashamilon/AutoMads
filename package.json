{
  "name": "facebook-order-automation-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant AI Facebook order automation + client integration platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "client:dev": "npm run dev --prefix client",
    "client:install": "npm install --prefix client",
    "client:build": "npm run build --prefix client",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit",
    "check:ollama": "node scripts/check-ollama.mjs",
    "seed:demo": "node scripts/seed-demo-tenant.mjs",
    "diagnose:fb": "node scripts/diagnose-fb-webhook.mjs",
    "subscribe:fb": "node scripts/subscribe-page.mjs",
    "jsonl:merge": "node scripts/merge-json-dir-to-jsonl.mjs",
    "rag:import": "node scripts/import-conversations.mjs",
    "rag:check": "node scripts/check-rag.mjs",
    "rag:reembed": "node scripts/reembed-knowledge.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/core": "^1.1.45",
    "@langchain/langgraph": "^1.3.0",
    "@prisma/client": "^6.3.0",
    "@types/yauzl": "^2.10.3",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "mysql2": "^3.12.0",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "qrcode": "^1.5.4",
    "tesseract.js": "^7.0.0",
    "uuid": "^11.0.5",
    "yauzl": "^3.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
